---
import Footer from "../layout/Footer.astro";
import Navbar from "../layout/Navbar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Eldoria: A Divided World",
  description = "Enter the world of Eldoria."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
  href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
  rel="stylesheet">
  <title>{title}</title>
</head>
<script type="module">

import "/src/scripts/reveal.js";

</script>
<body>

    <Navbar />

    <slot />

    <Footer />
    <script type="module">

const navbar = document.querySelector(".navbar");

window.addEventListener("scroll", () => {

    if (window.scrollY > 80) {

        navbar?.classList.add("scrolled");

    } else {

        navbar?.classList.remove("scrolled");

    }

});

</script>
</body>
</html>