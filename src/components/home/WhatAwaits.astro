---
import Section from "../ui/Section.astro";
---

<Section
    title="The Journey Begins"
    subtitle="Every path through Eldoria is different."
>

<div class="feature-grid">

    <article class="feature">

        <span class="number">I</span>

        <h3>Explore</h3>

        <p>

            Cross seven distinct regions filled with kingdoms,
            forgotten ruins, towering mountains, and cities that
            have endured for thousands of years.

        </p>

    </article>

    <article class="feature">

        <span class="number">II</span>

        <h3>Discover</h3>

        <p>

            Piece together ancient history through lost chronicles,
            myths, relics, and secrets hidden long before the story begins.

        </p>

    </article>

    <article class="feature">

        <span class="number">III</span>

        <h3>Witness</h3>

        <p>

            Experience a world where every kingdom, hero,
            and forgotten legend shapes the future of Eldoria.

        </p>

    </article>

</div>

</Section>

<style>

.feature-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:2.5rem;

}

.feature{

    position:relative;

    padding:3rem;

    border:1px solid var(--border);

    border-radius:12px;

    background:

        linear-gradient(

            180deg,

            rgba(23,19,16,.96),

            rgba(16,13,11,.98)

        );

    transition:

        transform .35s,

        border-color .35s,

        box-shadow .35s;

}

.feature::before{

    content:"";

    position:absolute;

    inset:0;

    border-radius:12px;

    background:

        radial-gradient(

            circle at top,

            rgba(198,166,107,.05),

            transparent 70%

        );

    pointer-events:none;

}

.feature:hover{

    transform:translateY(-8px);

    border-color:var(--primary);

    box-shadow:

        0 20px 45px rgba(0,0,0,.35);

}

.number{

    display:inline-block;

    font-family:"Cinzel",serif;

    font-size:2.5rem;

    color:var(--primary);

    margin-bottom:2rem;

}

.feature h3{

    font-size:2rem;

    margin-bottom:1.25rem;

    color:var(--text);

}

.feature p{

    line-height:2;

}

@media(max-width:900px){

.feature-grid{

    grid-template-columns:1fr;

}

}

</style>