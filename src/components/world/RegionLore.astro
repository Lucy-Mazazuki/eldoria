---
import RegionSection from "./RegionSection.astro";
---

<RegionSection

    title="Related Lore"

    subtitle="Continue exploring the world of Eldoria."

>

<div class="lore-grid">

    <a href="/characters" class="lore-card">

        <h3>Characters</h3>

        <p>

            Meet the heroes, rulers, and legends connected to Solmara.

        </p>

    </a>

    <a href="/specters" class="lore-card">

        <h3>Specters</h3>

        <p>

            Learn about the divine guardians who watch over Eldoria.

        </p>

    </a>

    <a href="/timeline" class="lore-card">

        <h3>Timeline</h3>

        <p>

            Discover the events that shaped the continent.

        </p>

    </a>

    <a href="/organizations" class="lore-card">

        <h3>Organizations</h3>

        <p>

            Explore guilds, orders, kingdoms, and powerful factions.

        </p>

    </a>

</div>

<div class="back">

    <a href="/world">

        ← Return to the Atlas

    </a>

</div>

</RegionSection>

<style>

.lore-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:2rem;

    margin-bottom:5rem;

}

.lore-card{

    padding:2.5rem;

    border-radius:20px;

    text-decoration:none;

    background:rgba(255,255,255,.03);

    border:1px solid rgba(198,166,107,.15);

    transition:.35s;

}

.lore-card:hover{

    transform:translateY(-8px);

    border-color:var(--primary);

}

.lore-card h3{

    font-family:"Cinzel",serif;

    color:white;

    margin-bottom:1rem;

}

.lore-card p{

    color:var(--muted);

    line-height:1.8;

}

.back{

    text-align:center;

}

.back a{

    color:var(--primary);

    text-decoration:none;

    font-size:1.05rem;

}

.back a:hover{

    text-decoration:underline;

}

@media(max-width:768px){

.lore-grid{

    grid-template-columns:1fr;

}

}

</style>