---
import RegionSection from "./RegionSection.astro";
---

<RegionSection

title="Places of Interest"

subtitle="Destinations every traveler should know."

>

<div class="places-grid">

<article>

<h3>Storgur War Arena</h3>

</article>

<article>

<h3>Grave of Eirlys</h3>

</article>

<article>

<h3>Valemore Grand Market</h3>

</article>

<article>

<h3>The Golden Tankard</h3>

</article>

<article>

<h3>Royal Academy of Aurelis</h3>

</article>

<article>

<h3>Eirlyc Adventurer Guild</h3>

</article>

</div>

</RegionSection>

<style>

.places-grid{

display:grid;

grid-template-columns:repeat(3,1fr);

gap:2rem;

}

.places-grid article{

padding:2rem;

border-radius:18px;

background:rgba(255,255,255,.03);

border:1px solid rgba(198,166,107,.15);

transition:.35s;

}

.places-grid article:hover{

transform:translateY(-6px);

border-color:var(--primary);

}

.places-grid h3{

font-family:"Cinzel",serif;

text-align:center;

}

@media(max-width:900px){

.places-grid{

grid-template-columns:repeat(2,1fr);

}

}

@media(max-width:600px){

.places-grid{

grid-template-columns:1fr;

}

}

</style>