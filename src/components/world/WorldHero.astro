<section class="world-hero">

    <p class="eyebrow">
        THE WORLD OF
    </p>

    <h1>
        Eldoria
    </h1>

    <div class="divider"></div>

    <p class="intro">

        Seven regions.
        Hundreds of years of history.
        Countless stories waiting to be discovered.

    </p>

</section>
<style>

.world-hero{

    min-height:60vh;

    display:flex;

    flex-direction:column;

    justify-content:center;

    align-items:center;

    text-align:center;

    gap:2rem;

    padding:8rem 2rem;

}

.eyebrow{

    color:var(--primary);

    letter-spacing:.35em;

    text-transform:uppercase;

    font-size:.85rem;

}

.world-hero h1{

    font-family:"Cinzel",serif;

    font-size:clamp(4rem,8vw,7rem);

    color:var(--text);

}

.divider{

    width:180px;

    height:1px;

    background:

        linear-gradient(

            90deg,

            transparent,

            var(--primary),

            transparent

        );

}

.intro{

    max-width:700px;

    line-height:2;

    color:var(--muted);

    font-size:1.1rem;

}
</style>