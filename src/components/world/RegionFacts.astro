---
import RegionSection from "./RegionSection.astro";
---

<RegionSection

    title="At a Glance"

    subtitle="Key facts about Solmara."

>

<div class="facts-grid">

    <div class="fact-card">

        <span>👑 Capital</span>

        <h3>Valemore</h3>

    </div>

    <div class="fact-card">

        <span>👥 Population</span>

        <h3>~500 Million</h3>

    </div>

    <div class="fact-card">

        <span>🏛 Government</span>

        <h3>Independent Monarchies</h3>

    </div>

    <div class="fact-card">

        <span>☀ Climate</span>

        <h3>Warm Year Round</h3>

    </div>

    <div class="fact-card">

        <span>💰 Currency</span>

        <h3>Eirlyc Gold And Bengs</h3>

    </div>

    <div class="fact-card">

        <span>🌾 Exports</span>

        <h3>Wheat • Sugarcane • Manicallus Crystals</h3>

    </div>

    <div class="fact-card">

        <span>⚓ Imports</span>

        <h3>Salt • Silver • Corn</h3>

    </div>

    <div class="fact-card">

        <span>🕊 Known For</span>

        <h3>Freedom And Affordable Living</h3>

    </div>

</div>

</RegionSection>

<style>

.facts-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:2rem;

}

.fact-card{

    padding:2rem;

    border-radius:20px;

    border:1px solid rgba(198,166,107,.15);

    background:rgba(255,255,255,.03);

    transition:.35s;

    text-align:center;

}

.fact-card:hover{

    transform:translateY(-8px);

    border-color:var(--primary);

    box-shadow:

        0 20px 40px rgba(0,0,0,.3),

        0 0 30px rgba(198,166,107,.08);

}

.fact-card span{

    display:block;

    color:var(--primary);

    text-transform:uppercase;

    letter-spacing:.2em;

    font-size:.75rem;

    margin-bottom:1rem;

}

.fact-card h3{

    font-family:"Cinzel",serif;

    color:white;

    font-size:1.3rem;

    line-height:1.5;

}

@media(max-width:900px){

.facts-grid{

    grid-template-columns:repeat(2,1fr);

}

}

@media(max-width:600px){

.facts-grid{

    grid-template-columns:1fr;

}

}

</style>