---
interface Props {

    title: string;

    subtitle?: string;

}

const {

    title,
    subtitle

} = Astro.props;
---

<section class="region-section">

    <div class="container">

        <div class="section-header">

            <div class="divider">

                <span></span>

                ⚜

                <span></span>

            </div>

            <h2>{title}</h2>

            {subtitle && <p>{subtitle}</p>}

        </div>

        <slot />

    </div>

</section>

<style>

.region-section{

    padding:7rem 0;

}

.container{

    width:min(1200px,92%);

    margin:auto;

}

.section-header{

    text-align:center;

    margin-bottom:4rem;

}

.divider{

    display:flex;

    align-items:center;

    justify-content:center;

    gap:1rem;

    margin-bottom:2rem;

    color:var(--primary);

}

.divider span{

    width:100px;

    height:1px;

    background:

        linear-gradient(

            90deg,

            transparent,

            var(--primary),

            transparent

        );

}

.section-header h2{

    font-family:"Cinzel",serif;

    font-size:clamp(2.5rem,5vw,4rem);

    color:var(--text);

    margin-bottom:1rem;

}

.section-header p{

    max-width:700px;

    margin:auto;

    color:var(--muted);

    line-height:1.9;

}

</style>