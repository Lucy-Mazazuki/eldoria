---
interface Props{

    title:string;
    tagline:string;
    image:string;
    href:string;

}

const{

    title,
    tagline,
    image,
    href

}=Astro.props;
---

<a
    href={href}
    class="region-card"
>

    <div class="region-image-wrapper">

        <img
            src={image}
            alt={title}
            class="region-image"
        />

        <div class="overlay"></div>

    </div>

<div class="content">

    <p class="eyebrow">

        {tagline}

    </p>

    <h2>

        {title}

    </h2>

<span class="enter">

    Explore {title} →

</span>
</div>
</a>
<style>

.region-card{
    display:grid;
    
    grid-template-columns:1.2fr .8fr;

    align-items:center;

    min-height:520px;

    overflow:hidden;

    border-radius:28px;

    border:1px solid rgba(198,166,107,.15);
    
    background:rgba(255,255,255,.02);

    box-shadow:var(--shadow);
    
    cursor:pointer;
    
    transition:
        transform .4s ease,
        border-color .4s ease;

}

.region-image{

    width:100%;

    height:100%;

    object-fit:cover;

    transition:

        transform .8s ease,

        filter .8s ease;

}
.overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            to top,

            rgba(0,0,0,.75),

            rgba(0,0,0,.35),

            rgba(0,0,0,.05)

        );

}
.content{

    padding:4rem;

}

.content h2{

    font-size:clamp(3rem,5vw,4rem);

    margin-bottom:.75rem;

    color:white;

}
.eyebrow{

    color:var(--primary);

    text-transform:uppercase;

    letter-spacing:.35em;

    font-size:.8rem;

    margin-bottom:1rem;

}
.enter{

    color:var(--primary);

    font-weight:600;

    transition:.3s;

}
.content h2{

    font-size:clamp(3rem,5vw,4rem);

    color:white;

    margin-bottom:2rem;

}
.region-card:hover{

    transform:

        translateY(-8px)

        scale(1.01);


    border-color:var(--primary);

    box-shadow:

        0 30px 80px rgba(0,0,0,.45),

        0 0 40px rgba(198,166,107,.12);

}
.region-card:hover .region-image{

    transform:scale(1.06);

}

.region-card:hover .enter{

    letter-spacing:.08em;

}

@media(max-width:768px){

    .region-card{

        grid-template-columns:1fr;

    }

    .region-card:nth-child(even){

        grid-template-columns:1fr;

    }

    .region-image-wrapper{

        min-height:260px;

    }

    .region-card:nth-child(even) .region-image-wrapper{

        order:1;

    }

    .region-card:nth-child(even) .content{

        order:2;

    }

    .content{

        padding:2rem;

    }

}
.region-image-wrapper{

    position:relative;

    min-height:520px;

    overflow:hidden;

}
.region-card:nth-child(even){

    grid-template-columns:.8fr 1.2fr;

}

.region-card:nth-child(even) .region-image-wrapper{

    order:2;

}

.region-card:nth-child(even) .content{

    order:1;

}
</style>