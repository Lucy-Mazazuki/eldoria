---
import Button from "../ui/Button.astro";

interface Props{

    title:string;
    description:string;
    href:string;
    logo:string;
    variant?:"primary"|"secondary";

}

const{

    title,
    description,
    href,
    logo,
    variant="secondary"

}=Astro.props;
---

<article class="platform-card">

    <img
        src={logo}
        alt={title}
        class="logo"
    />

    <h2>

        {title}

    </h2>

    <p>

        {description}

    </p>

    <Button
        href={href}
        variant={variant}
    >

        Read Now →

    </Button>

</article>

<style>

.platform-card{

    display:flex;

    flex-direction:column;

    align-items:center;

    justify-content:center;

    gap:1.5rem;

    padding:3rem;

    border-radius:24px;

    background:var(--surface);

    border:1px solid var(--border);

    transition:var(--transition);

    text-align:center;

    height:100%;

}

.platform-card:hover{

    transform:translateY(-10px);

    border-color:var(--primary);

    box-shadow:var(--shadow-hover);

}

.logo{

    width:72px;

    height:72px;

    object-fit:contain;

}

.platform-card h2{

    font-family:"Cinzel",serif;

    font-size:2rem;

    color:var(--text);

}

.platform-card p{

    color:var(--muted);

    line-height:1.8;

    max-width:260px;

}
.community{

    width:min(900px,92%);

    margin:8rem auto;

    text-align:center;

}

.community .eyebrow{

    color:var(--primary);

    text-transform:uppercase;

    letter-spacing:.35em;

    margin-bottom:1rem;

}

.community h2{

    font-family:"Cinzel",serif;

    font-size:clamp(2.5rem,5vw,4rem);

    margin-bottom:1rem;

}

.community p{

    color:var(--muted);

    line-height:2;

    max-width:650px;

    margin:0 auto 3rem;

}

.socials{

    display:flex;

    justify-content:center;

    flex-wrap:wrap;

    gap:1.5rem;

}

.socials a{

    padding:1rem 2rem;

    border:1px solid var(--border);

    border-radius:999px;

    color:var(--text);

    text-decoration:none;

    transition:var(--transition);

    background:var(--surface);

}

.socials a:hover{

    border-color:var(--primary);

    color:var(--primary);

    transform:translateY(-4px);

}
</style>