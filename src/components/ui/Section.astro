---
interface Props{

    title?:string;

    subtitle?:string;

}

const{

    title,

    subtitle

}=Astro.props;
---

<section class="section reveal">
    <div class="section-inner">

        {title || subtitle ? (

        <header class="section-header">

            <div class="divider">

                <span></span>

                ⚜

                <span></span>

            </div>

            {title && (
                <h2>{title}</h2>
            )}

            {subtitle && (
                <p>{subtitle}</p>
            )}

        </header>

        ) : null}
        <slot/>

    </div>

</section>

<style>

.section{

    position:relative;

    padding:9rem 0;

}

.section-inner{

    width:min(1200px,92%);

    margin:auto;

}

.section-header{

    margin-bottom:5rem;

    text-align:center;

}

.divider{

    display:flex;

    align-items:center;

    justify-content:center;

    gap:1rem;

    margin-bottom:2rem;

    color:var(--primary);

    letter-spacing:.3em;

}

.divider span{

    width:110px;

    height:1px;

    background:

        linear-gradient(

            90deg,

            transparent,

            var(--primary),

            transparent

        );

}

.section h2{

    font-size:clamp(2.5rem,5vw,4rem);

    color:var(--text);

    margin-bottom:1rem;

    letter-spacing:.08em;

}

.section-header p{

    max-width:650px;

    margin:auto;

    color:var(--muted);

    line-height:1.9;

    font-size:1.05rem;

}

@media(max-width:768px){

.section{

    padding:6rem 0;

}

.divider span{

    width:60px;

}

}

</style>