---
interface Props{

    title:string;

}

const{

    title

}=Astro.props;
---

<div class="card">

    <h3>{title}</h3>

    <slot/>

</div>

<style>

.card{

    background:rgba(255,255,255,.03);

    border:1px solid rgba(255,255,255,.06);

    border-radius:18px;

    padding:2rem;

    transition:.35s ease;

}

.card:hover{

    transform:translateY(-8px);

    border-color:var(--primary);

    box-shadow:

        0 0 40px rgba(198,166,107,.06);

}

.card h3{

    margin-bottom:1rem;

}

</style>